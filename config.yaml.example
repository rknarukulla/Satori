# Satori Configuration Template
# ─────────────────────────────────────────────────────────────
# 1. Copy this file:   cp config.yaml.example config.yaml
# 2. Fill in your credentials below
# 3. config.yaml is gitignored — it never leaves your machine
# ─────────────────────────────────────────────────────────────

meta:
  # Your Meta Graph API long-lived token (starts with EAA...)
  # Get one at: https://developers.facebook.com/tools/explorer/
  # See docs/token-setup.md for step-by-step instructions
  token: "EAA_PASTE_YOUR_TOKEN_HERE"

  # Your Instagram Business Account ID (17 digits, starts with 17841...)
  # Claude will help you find this during setup
  account_id: "17841XXXXXXXXXX"

  # Your Instagram handle (display only — used in report headers)
  account_name: "yourhandle"

llama:
  # Optional: Llama API key for enhanced metric narrative and vision analysis
  # Get one at: https://llama.developer.meta.com/
  # Leave blank to use Claude-only analysis (still very good)
  api_key: ""

playstore:
  # Google Play Developer API credentials
  # See docs/playstore-setup.md for step-by-step instructions

  # Path to your service account JSON key file (never paste key contents here)
  # Place it in credentials/ — that folder is gitignored
  service_account_key_path: "credentials/playstore-service-account.json"

  # Your app's package name (e.g. com.yourcompany.yourapp)
  package_name: "com.example.yourapp"

  # Display name used in reports
  app_name: "Your App Name"

appstore:
  # Apple App Store Connect API credentials
  # See docs/appstore-setup.md for step-by-step instructions

  # Path to your .p8 EC private key — download once from App Store Connect, never paste here
  # Place it in credentials/ — that folder is gitignored
  key_path: "credentials/appstore-key.p8"

  # 10-character Key ID — App Store Connect > Users & Access > Integrations > App Store Connect API
  key_id: "XXXXXXXXXX"

  # Issuer ID (UUID) — shown at the top of the same App Store Connect page
  issuer_id: "xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"

  # Numeric Apple ID for your app — App Store Connect > My Apps > App Information > Apple ID
  # Note: this is NOT the bundle ID (com.example.app) — it's a plain number like 123456789
  app_apple_id: "123456789"

  # Vendor Number — App Store Connect > Payments and Financial Reports
  # Required for sales/download reports; leave blank to skip sales data
  vendor_number: "12345678"

  # Display name used in reports
  app_name: "Your App Name"

linkedin:
  # LinkedIn Pages API credentials
  # See docs/linkedin-setup.md for step-by-step instructions

  # OAuth2 access token — expires every 60 days, refresh via LinkedIn Developer Portal
  # Get one at: https://www.linkedin.com/developers/apps
  access_token: "AQX_PASTE_YOUR_TOKEN_HERE"

  # Your LinkedIn Company Page numeric ID (not the vanity URL slug)
  # Find it: LinkedIn > Admin tools > Super admin view — the number in the URL
  org_id: "12345678"

  # Your company page display name (used in reports)
  org_name: "Your Company Name"

satori:
  # Your timezone — used for scheduling and "best time to post" analysis
  # Examples: America/New_York, America/Los_Angeles, Europe/London, Asia/Kolkata
  timezone: "America/New_York"

  # Optional: describe your brand's tone for caption generation
  # Example: "friendly and relatable, uses we/us language, avoids jargon"
  brand_voice: ""

  # Optional: your content niche (helps with trend research)
  # Example: "personal finance app for Gen Z"
  niche: ""

  # Auto-managed by Satori — tracks when platform docs were last checked
  # Satori re-fetches Meta changelog and algorithm updates if older than 7 days
  platform_last_checked: ""
